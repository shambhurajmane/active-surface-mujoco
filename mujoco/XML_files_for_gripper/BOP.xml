<mujoco model="panda hand">
  <compiler angle="radian" meshdir="assets" autolimits="true"/>

  <option integrator="implicitfast"/>

  <default>

    <default class="panda">
      <material specular="0.5" shininess="0.25"/>
      <joint armature="0.1" damping="1" axis="0 0 1" range="-2.8973 2.8973"/>
      <general dyntype="none" biastype="affine" ctrlrange="-2.8973 2.8973" forcerange="-87 87"/>
      <default class="finger">
        <joint axis="0 1 0" type="slide" range="0 0.04"/>
      </default>

      <default class="visual">
        <geom type="mesh" contype="0" conaffinity="0" group="2"/>
      </default>
      <default class="collision">
        <geom type="mesh" group="3"/>
        <default class="fingertip_pad_collision_1">
          <geom type="box" size="0.0085 0.004 0.0085" pos="0 0.0055 0.0445"/>
        </default>
        <default class="fingertip_pad_collision_2">
          <geom type="box" size="0.003 0.002 0.003" pos="0.0055 0.002 0.05"/>
        </default>
        <default class="fingertip_pad_collision_3">
          <geom type="box" size="0.003 0.002 0.003" pos="-0.0055 0.002 0.05"/>
        </default>
        <default class="fingertip_pad_collision_4">
          <geom type="box" size="0.003 0.002 0.0035" pos="0.0055 0.002 0.0395"/>
        </default>
        <default class="fingertip_pad_collision_5">
          <geom type="box" size="0.003 0.002 0.0035" pos="-0.0055 0.002 0.0395"/>
        </default>
      </default>
    </default>
  </default>

  <asset>
    <material class="panda" name="white" rgba="1 1 1 1"/>
    <material class="panda" name="off_white" rgba="0.901961 0.921569 0.929412 1"/>
    <material class="panda" name="black" rgba="0.25 0.25 0.25 1"/>
    <material name="mat_black" rgba="0 0 0 1" specular="0" reflectance="0.2" shininess="0.2" emission="0.2"/>


    <!-- Collision meshes -->
    <mesh name="hand_c" file=".\assets\BOP_CAD\franka_hand_assets\hand.stl"/>

    <!-- Visual meshes -->
    <mesh file=".\assets\BOP_CAD\franka_hand_assets\hand_0.obj"/>
    <mesh file=".\assets\BOP_CAD\franka_hand_assets\hand_1.obj"/>
    <mesh file=".\assets\BOP_CAD\franka_hand_assets\hand_2.obj"/>
    <mesh file=".\assets\BOP_CAD\franka_hand_assets\hand_3.obj"/>
    <mesh file=".\assets\BOP_CAD\franka_hand_assets\hand_4.obj"/>
    <mesh file=".\assets\BOP_CAD\franka_hand_assets\finger_0.obj"/>
    <mesh file=".\assets\BOP_CAD\franka_hand_assets\finger_1.obj"/>


    <mesh name="PandaFingerMount" file=".\assets\BOP_CAD\STL_files\PandaFingerMount.STL"  scale="0.001 0.001 0.001"  />
    <mesh name="Gt3Belt" file=".\assets\BOP_CAD\STL_files\GT3Belt.STL"  scale="0.001 0.001 0.001"  />
    <mesh name="FingerSide1" file=".\assets\BOP_CAD\STL_files\BeltFingerSide1.STL"  scale="0.001 0.001 0.001"  />
    <mesh name="FingerSide2" file=".\assets\BOP_CAD\STL_files\BeltFingerSide2.STL"  scale="0.001 0.001 0.001"  />

    <mesh name="Hexagon" file=".\assets\test_objects\hex.stl"  scale="0.01 0.01 0.01"  />

  </asset>

  <worldbody>
    <light diffuse=".5 .5 .5" pos="0 1 3" dir="0 0 -1"/>

    <!-- Draw ground plane -->
    <geom type="plane" size="1 1 0.001" pos="0 0 0"  material="mat_black"/>
    <geom type="box" size="0.1 0.1 0.06" pos="0 0.15 0.06" material="black"/>

    <!-- Spawn a square object to be grasped (very low friction #"0.2 0.002 0.0001") -->
    <!-- <body name="curr_object" pos="0.0 0.13 0.162">
      <joint type="free"/>
      <geom type="box" size=".02 .02 .04" rgba="0 .9 0 1" friction="0.1 0.002 0.0001"/>  
      <site name="obj_frame" pos="0 0 0" quat="1 0 0 0" rgba="0 1 0 1" size=".02"/>
    </body> -->

    <body name="curr_object" pos="0.0 0.13 0.1802" quat="0.9659 0 0 0.2588">
    <joint type="free"/>

    <geom
      type="mesh"
      mesh="Hexagon"
      rgba="0 .9 0 1"
      friction="0.1 0.002 0.0001"/>

    <site
      name="obj_frame"
      pos="0 0 0"
      quat="1 0 0 0"
      rgba="0 1 0 1"
      size=".002"/>
  </body>

    <!-- Spawn a cylindrical object to be grasped -->
    <!-- <body name="cyl_object" pos="0.0 0.13 0.162">
      <joint type="free"/>
      <geom
        type="cylinder"
        size="0.02 0.04"
        rgba="0 .9 0 1"
        friction="0.1 0.002 0.0001"/>
      <site
        name="obj_frame"
        pos="0 0 0"
        quat="1 0 0 0"
        rgba="0 1 0 1"
        size=".02"/>
    </body> -->

    <camera name="fixed_camera" pos="0.0 0.1 0.8" xyaxes="1 0 0 0 1 0"/>


    <body name="stand" pos="0 0 0.25">
      <geom type="box" size=".02 .01 .25" friction="0.1 0.002 0.0001" material="black"/>  
      <body name="hand" childclass="panda" quat="-0.5 0.5 0.5 0.5" pos="0 0.02 0.04">
        <joint name="hand_slide" type="slide" axis="1 0 0"
                          range="-0.3 0.3" damping="20" armature="0.001" />
        <inertial mass="0.73" pos="-0.01 0 0.03" diaginertia="0.001 0.0025 0.0017"/>
        <geom mesh="hand_0" material="off_white" class="visual"/>
        <geom mesh="hand_1" material="black" class="visual"/>
        <geom mesh="hand_2" material="black" class="visual"/>
        <geom mesh="hand_3" material="white" class="visual"/>
        <geom mesh="hand_4" material="off_white" class="visual"/>
        <geom mesh="hand_c" class="collision"/>
        <body name="left_finger" pos="0 0 0.0584">
          <inertial mass="0.015" pos="0 0 0" diaginertia="2.375e-6 2.375e-6 7.5e-7"/>
          <joint name="finger_joint1" class="finger"/>
          <body name="panda_finger_mount_1" pos="0.016 0.043 0.0" quat ="0.5 0.5 -0.5 -0.5" >
            <geom type="mesh" mesh="PandaFingerMount" name="geom_panda_finger_mount_1"/>
            <body name="finger_side1_1" pos="0.0027 0.008 0.002" >
              <geom type="mesh" mesh="FingerSide1" name="geom_finger_side_1_1"/>
              <body name="gt3_belt_1_1" pos="0.010 0.0 0.004" > 
                <geom type="mesh" mesh="Gt3Belt" name="geom_gt3_belt_1_1"/>
                <body name="moving_finger1_1" pos="0.025 0.044 0.001" quat ="0.5 -0.5 0.5 0.5" >
                  <geom type="box" size="0.0085 0.004 2" rgba="0.8 0.1 0.1 0.3"/>
                  <joint name="finger1_slide_1" type="slide" axis="0 0 1"
                          range="-3 3" damping="20" armature="0.001" />
                </body>
              </body>
            </body>
            <body name="finger_side2_1" pos="0.0027 0.008 0.016" >
              <geom type="mesh" mesh="FingerSide2" name="geom_finger_side_2_1"/>
              <body name="gt3_belt_2_1" pos="0.010 0.0 0.002" >
                <geom type="mesh" mesh="Gt3Belt" name="geom_gt3_belt_2_1"/>
                <body name="moving_finger2_1" pos="0.025 0.044 0.009" quat ="0.5 -0.5 0.5 0.5">
                  <geom type="box" size="0.0085 0.004 2" rgba="0.8 0.1 0.1 0.3"/>
                  <joint name="finger2_slide_1" type="slide" axis="0 0 1"
                          range="-3 3" damping="20" armature="0.001" />
                </body>
              </body>
            </body>
          </body>
    
        </body>
        <body name="right_finger" pos="0 0 0.0584" quat="0 0 0 1">
          <inertial mass="0.015" pos="0 0 0" diaginertia="2.375e-6 2.375e-6 7.5e-7"/>
          <joint name="finger_joint2" class="finger"/>
          <body name="panda_finger_mount_2" pos="0.016 0.043 0.0" quat ="0.5 0.5 -0.5 -0.5" >
            <geom type="mesh" mesh="PandaFingerMount" name="geom_panda_finger_mount_2"/>
            <body name="finger_side1_2" pos="0.0027 0.008 0.002" >
              <geom type="mesh" mesh="FingerSide1" name="geom_finger_side_1_2"/>
              <body name="gt3_belt_1_2" pos="0.010 0.0 0.004" > 
                <geom type="mesh" mesh="Gt3Belt" name="geom_gt3_belt_1_2"/>
                <body name="moving_finger1_2" pos="0.025 0.044 0.001" quat ="0.5 -0.5 0.5 0.5">
                  <geom type="box" size="0.0085 0.004 2" rgba="0.8 0.1 0.1 0.3"/>
                  <joint name="finger1_slide_2" type="slide" axis="0 0 1"
                          range="-3 3" damping="20" armature="0.001"  />
                </body>
              </body>
            </body>
            <body name="finger_side2_2" pos="0.0027 0.008 0.016" >
              <geom type="mesh" mesh="FingerSide2" name="geom_finger_side_2_2"/>
              <body name="gt3_belt_2_2" pos="0.010 0.0 0.002" >
                <geom type="mesh" mesh="Gt3Belt" name="geom_gt3_belt_2_2"/>
                <body name="moving_finger2_2" pos="0.025 0.044 0.009" quat ="0.5 -0.5 0.5 0.5">
                  <geom type="box" size="0.0085 0.004 2" rgba="0.8 0.1 0.1 0.3"/>
                  <joint name="finger2_slide_2" type="slide" axis="0 0 1"
                          range="-3 3" damping="20" armature="0.001" />
                </body>
              </body>
            </body>
          </body>
      
        </body>
      </body>
    </body>
  </worldbody>

  <contact>
    <exclude body1="hand" body2="stand"/>

    <exclude body1="hand" body2="left_finger"/>
    <exclude body1="hand" body2="panda_finger_mount_1"/>

    <exclude body1="moving_finger1_1" body2="left_finger"/>
    <exclude body1="moving_finger1_1" body2="hand"/>
    <exclude body1="moving_finger1_1" body2="right_finger"/>
    <exclude body1="moving_finger1_1" body2="stand"/>


    <exclude body1="moving_finger2_1" body2="left_finger"/>
    <exclude body1="moving_finger2_1" body2="hand"/>
    <exclude body1="moving_finger2_1" body2="right_finger"/>
    <exclude body1="moving_finger2_1" body2="stand"/>


    <exclude body1="hand" body2="right_finger"/>
    <exclude body1="hand" body2="panda_finger_mount_2"/>
    <exclude body1="moving_finger1_2" body2="left_finger"/>
    <exclude body1="moving_finger1_2" body2="hand"/>
    <exclude body1="moving_finger1_2" body2="right_finger"/>
    <exclude body1="moving_finger1_2" body2="stand"/>

    <exclude body1="moving_finger2_2" body2="left_finger"/>
    <exclude body1="moving_finger2_2" body2="hand"/>
    <exclude body1="moving_finger2_2" body2="right_finger"/>
    <exclude body1="moving_finger2_2" body2="stand"/>
  </contact>

  <tendon>
    <fixed name="split">
      <joint joint="finger_joint1" coef="0.5"/>
      <joint joint="finger_joint2" coef="0.5"/>
    </fixed>
  </tendon>

  <equality>
    <joint joint1="finger_joint1" joint2="finger_joint2" solimp="0.95 0.99 0.001" solref="0.005 1"/>
    <!-- <joint joint1="finger1_slide_1" joint2="finger2_slide_2" solimp="0.95 0.99 0.001" solref="0.005 1"/>
    <joint joint1="finger2_slide_1" joint2="finger1_slide_2" solimp="0.95 0.99 0.001" solref="0.005 1"/> -->
  </equality>

  <actuator>
    <position name="hand_actuator" joint="hand_slide" kp="1500" kv="50"  ctrlrange="-0.3 0.3"/>
    <general class="panda" name="actuator8" tendon="split" forcerange="-100 100" ctrlrange="0 255"
      gainprm="0.01568627451 0 0" biasprm="0 -100 -10" />
    <position name="left_belt_1_actuator" joint="finger1_slide_1" kp="1500" kv="50"  ctrlrange="-3 3"/>
    <position name="left_belt_2_actuator" joint="finger2_slide_1" kp="1500" kv="50"  ctrlrange="-3 3"/>
    <position name="right_belt_1_actuator" joint="finger2_slide_2" kp="1500" kv="50"  ctrlrange="-3 3"/>
    <position name="right_belt_2_actuator" joint="finger1_slide_2" kp="1500" kv="50"  ctrlrange="-3 3"/>
  </actuator>

  <sensor>
    <jointpos name="hand_pos_sensor" joint="hand_slide" />
    <jointpos name="palm_pos_sensor" joint="finger_joint1" />
    <actuatorfrc name="palm_force_sensor" actuator="actuator8" />

    <jointpos name="left_belt_1_sensor" joint="finger1_slide_1" />
    <jointpos name="left_belt_2_sensor" joint="finger2_slide_1" />
    <jointpos name="right_belt_1_sensor" joint="finger2_slide_2" />
    <jointpos name="right_belt_2_sensor" joint="finger1_slide_2" />

    <framepos name ="obj_pos" objtype="body" objname="curr_object" reftype="body" refname="hand"/>
    <framequat name ="obj_quat" objtype="body" objname="curr_object" reftype="body" refname="hand"/>
  </sensor>
</mujoco>
