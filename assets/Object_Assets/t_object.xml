<mujoco model="t_object_example">
  <asset>
    <!-- Optional: define materials here -->
  </asset>

  <worldbody>
    <!-- Free-floating T-shaped object -->
    <body name="t_object" pos="0 0 0.2">
      <joint type="free"/>

      <!-- Vertical part of T -->
      <geom name="t_vert"
            type="box"
            size="0.02 0.02 0.06"
            pos="0 0 0"
            rgba="0 0.9 0 1"
            friction="0.5 0.002 0.0001"/>

      <!-- Horizontal top part of T -->
      <geom name="t_horiz"
            type="box"
            size="0.05 0.02 0.02"
            pos="0 0 0.06" 
            rgba="0 0.5 0.8 1"
            friction="0.5 0.002 0.0001"/>

      <!-- Reference site at center of object -->
      <site name="obj_frame"
            pos="0 0 0"
            size="0.02"
            rgba="1 0 0 1"/>
    </body>
  </worldbody>

  <option timestep="0.002" gravity="0 0 -9.81"/>
</mujoco>
